{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["gradle.properties"],
      "matchStrings": ["riteLsVersion=(?<currentValue>[^\\n]+)"],
      "depNameTemplate": "rite-ls",
      "packageNameTemplate": "rite-ly/rite",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$",
      "autoReplaceStringTemplate": "riteLsVersion={{{newValue}}}"
    }
  ],
  "postUpgradeTasks": {
    "commands": ["scripts/download-rite-ls.sh {{{newVersion}}}"],
    "fileFilters": ["src/main/resources/bin/**"],
    "executionMode": "branch"
  }
}
